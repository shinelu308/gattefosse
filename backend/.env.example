# 数据库配置
DATABASE_URL="postgresql://gattefosse:gattefosse_dev@localhost:5432/gattefosse_db?schema=public"

# JWT 密钥
JWT_SECRET="Gattefosse_JWT_Secret_Key_2026_Change_In_Production"
